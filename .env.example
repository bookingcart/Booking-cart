# Copy this file to .env and fill in your values.
# Generate BETTER_AUTH_SECRET with: openssl rand -hex 32

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/bookingcart

# ── better-auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=replace_me_with_openssl_rand_hex_32
BETTER_AUTH_URL=http://localhost:3000

# ── Next.js public vars ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Duffel (flights) ──────────────────────────────────────────────────────────
DUFFEL_API_KEY=duffel_test_...

# ── Events ────────────────────────────────────────────────────────────────────
EVENTBRITE_TOKEN=
TICKETMASTER_API_KEY=

# ── Cloudflare R2 (ticket storage) ───────────────────────────────────────────
# Create an R2 bucket in your Cloudflare dashboard, generate an API token
# with Object Read & Write, then fill in the four values below.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bookingcart-tickets
# Optional: custom domain or R2.dev public URL for the bucket (no trailing slash).
# If blank, the app issues signed 7-day download URLs automatically.
R2_PUBLIC_URL=


# Optional: Amadeus (debug scripts only)
# AMADEUS_API_KEY=
# AMADEUS_API_SECRET=
